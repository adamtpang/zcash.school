# zcash.school environment variables
# Copy to .env for local dev. In production, set these in the Vercel
# project (Settings -> Environment Variables). NEVER commit a real .env.

# --- /claim submission delivery (src/pages/api/claim.ts) ---

# Resend API key. Get one at https://resend.com. If unset, claims still
# succeed for the visitor and are written to the Vercel function log
# (recoverable), but no email is sent. Set this so the owner is notified.
RESEND_API_KEY=

# Where claim notifications are emailed.
CLAIM_NOTIFY_EMAIL=adam@zcash.school

# Sender address for the notification email. The domain MUST be verified
# in Resend or delivery will fail. Defaults to claims@zcash.school.
CLAIM_FROM_EMAIL=claims@zcash.school
