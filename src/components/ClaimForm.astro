---
/**
 * Progressive-enhancement claim form. Lives as an Astro component (not
 * inline in MDX) because MDX parses `{ }` as JSX expressions and would
 * choke on the script's object literals. Posts JSON to /api/claim,
 * shows inline status, no page reload. A <noscript> mailto fallback is
 * rendered in the MDX page for the JS-off case.
 */
---

<form id="claim-form" class="claim-form">
	<label>
		<span class="lbl">Your Unified Address (starts with <code>u1</code>)</span>
		<input
			type="text"
			name="unifiedAddress"
			required
			minlength="20"
			autocomplete="off"
			autocapitalize="off"
			spellcheck="false"
			placeholder="u1aa3kmwerpyu5p4tc3h3xqz..."
			class="mono"
		/>
		<small>In Zodl (formerly Zashi): tap <strong>Receive</strong> and copy the string starting with <code>u1</code>.</small>
	</label>

	<label>
		<span class="lbl">Which event or office hours did you attend?</span>
		<input type="text" name="event" required placeholder="e.g. Sat 16 May event · The Hall" />
	</label>

	<label>
		<span class="lbl">Contact (optional, for follow-up)</span>
		<input type="text" name="contact" placeholder="Email, Signal, WhatsApp, whatever you check" />
		<small>Only used if there's a problem with your claim. We don't add anyone to any list.</small>
	</label>

	{/* Honeypot: hidden from people, irresistible to bots. */}
	<input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" class="hp" />

	<button type="submit">Submit claim</button>
	<p id="claim-status" role="status" aria-live="polite"></p>
</form>

<script>
	const form = document.getElementById('claim-form') as HTMLFormElement | null;
	if (form) {
		const status = document.getElementById('claim-status') as HTMLParagraphElement;
		const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			status.style.color = 'inherit';
			status.textContent = 'Sending...';
			btn.disabled = true;
			const payload = Object.fromEntries(new FormData(form).entries());
			try {
				const r = await fetch('/api/claim', {
					method: 'POST',
					headers: { 'content-type': 'application/json' },
					body: JSON.stringify(payload),
				});
				const data = await r.json().catch(() => ({}));
				if (r.ok && data.ok) {
					form.reset();
					status.style.color = 'var(--zs-red, #E5322D)';
					status.textContent =
						data.message ||
						'Claim received. ZEC sent within 24 hours. See you at the next event.';
					const w = window as any;
					if (typeof w.va === 'function') w.va('event', { name: 'claim_submitted' });
				} else {
					status.style.color = '#b91c1c';
					status.textContent =
						(data && data.error) ||
						'Something went wrong. Email adam@zcash.school with your u1 address.';
					btn.disabled = false;
				}
			} catch {
				status.style.color = '#b91c1c';
				status.textContent =
					'Network error. Email adam@zcash.school with your u1 address and event.';
				btn.disabled = false;
			}
		});
	}
</script>

<style>
	.claim-form {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		max-width: 560px;
		margin: 1.5rem 0;
	}
	.claim-form label {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}
	.claim-form .lbl {
		font-weight: 600;
	}
	.claim-form input {
		padding: 0.6rem 0.8rem;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 6px;
		background: var(--sl-color-bg-nav);
		color: var(--sl-color-white);
		font-size: 1rem;
	}
	.claim-form input.mono {
		font-family: var(--sl-font-mono);
		font-size: 0.9rem;
	}
	.claim-form small {
		color: var(--sl-color-gray-3);
	}
	.claim-form .hp {
		position: absolute;
		left: -9999px;
		width: 1px;
		height: 1px;
		opacity: 0;
	}
	.claim-form button {
		padding: 0.75rem 1rem;
		background: var(--zs-red, #e5322d);
		color: #fff;
		border: 0;
		border-radius: 6px;
		font-weight: 700;
		cursor: pointer;
		font-size: 1rem;
	}
	.claim-form button:disabled {
		opacity: 0.6;
		cursor: progress;
	}
	#claim-status {
		margin: 0;
		min-height: 1.2rem;
		font-weight: 600;
	}
</style>
